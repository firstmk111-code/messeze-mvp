# ============================================================
#  MESSEZE MVP 백엔드 환경변수 (.env.example)
#  → 이 파일을 복사해 ".env" 로 저장한 뒤 값을 채우세요.
#  → 실제 키가 담긴 .env 는 절대 GitHub 에 올리지 마세요. (.gitignore 로 제외됨)
# ============================================================

# Resend API Key — https://resend.com → API Keys 에서 발급 (re_ 로 시작)
RESEND_API_KEY=

# 보내는 사람 주소 — Resend 에서 인증(verify)한 도메인 주소여야 함
#  · 테스트용으로는 onboarding@resend.dev 사용 가능 (본인 계정 이메일로만 수신됨)
#  · 예: MESSEZE <noreply@yourdomain.com>
FROM_EMAIL=onboarding@resend.dev

# 프런트엔드 주소 (CORS 허용). 비워두면 개발용으로 전체 허용.
#  · 배포 후에는 반드시 GitHub Pages 주소로 고정하세요.
#  · 예: https://your-id.github.io
#  · 여러 개면 콤마로 구분: https://your-id.github.io,http://localhost:5500
FRONTEND_URL=

# 서버 포트 (Render/Vercel 은 자동 주입, 로컬 기본 4000)
PORT=4000

# 기자 DB 복호화 키 (data/reporters.enc 복호화용, 64자리 hex)
#  · 로컬에 평문 data/reporters.json 이 있으면 불필요
#  · 운영(Render)에서는 이 키가 있어야 기자DB가 로드됨
REPORTERS_KEY=
